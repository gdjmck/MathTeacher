# Math Tutor 配置文件

# LLM 配置
LLM_PROVIDER=mock  # 可选: openai, anthropic, mock
LLM_MODEL=gpt-4    # OpenAI模型名称
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# 后端配置
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OCR 配置
OCR_PROVIDER=auto  # 可选: auto, tesseract, openai
OCR_LANGUAGES=eng
OPENAI_OCR_MODEL=gpt-4o-mini

# API 密钥（实际使用时填写）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 应用配置
APP_NAME=Math Tutor
APP_VERSION=0.1.0
DEBUG=true

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/mathtutor.log
